---
---
<form class="bg-white p-8 md:p-10 shadow-xl rounded-sm border-t-4 border-teal-700" action="https://formspree.io/f/placeholder" method="POST">
  <div class="mb-8">
    <h3 class="text-2xl font-bold text-slate-900 mb-2">Request a Free Estimate</h3>
    <p class="text-slate-600">Fill out the form below and Anthony will get back to you shortly to discuss your project.</p>
  </div>
  
  <div class="space-y-6">
    <div>
      <label for="name" class="block text-sm font-bold text-slate-900 mb-2">Full Name</label>
      <input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-sm focus:ring-2 focus:ring-teal-700 focus:border-teal-700 outline-none transition-shadow text-slate-900" placeholder="John Doe" />
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="email" class="block text-sm font-bold text-slate-900 mb-2">Email Address</label>
        <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-sm focus:ring-2 focus:ring-teal-700 focus:border-teal-700 outline-none transition-shadow text-slate-900" placeholder="john@example.com" />
      </div>
      <div>
        <label for="phone" class="block text-sm font-bold text-slate-900 mb-2">Phone Number</label>
        <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-sm focus:ring-2 focus:ring-teal-700 focus:border-teal-700 outline-none transition-shadow text-slate-900" placeholder="(917) 555-0123" />
      </div>
    </div>
    
    <div>
      <label for="service" class="block text-sm font-bold text-slate-900 mb-2">Primary Service Needed</label>
      <div class="relative">
        <select id="service" name="service" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-sm focus:ring-2 focus:ring-teal-700 focus:border-teal-700 outline-none transition-shadow appearance-none text-slate-900">
          <option value="" disabled selected>Select a Service</option>
          <option value="Bathroom Remodel">Bathroom Remodel</option>
          <option value="Kitchen Remodel">Kitchen Remodel</option>
          <option value="Tile Installation">Tile Installation</option>
          <option value="Grout Repair/Replace">Grout Repair/Replace</option>
          <option value="Commercial Services">Commercial Services</option>
          <option value="Other">Other</option>
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-700">
          <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
        </div>
      </div>
    </div>
    
    <div>
      <label for="description" class="block text-sm font-bold text-slate-900 mb-2">Project Details</label>
      <textarea id="description" name="description" rows="5" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-sm focus:ring-2 focus:ring-teal-700 focus:border-teal-700 outline-none transition-shadow resize-y text-slate-900" placeholder="Tell us a little about what you're looking to have done..."></textarea>
    </div>
    
    <button type="submit" class="w-full bg-slate-900 text-white font-bold py-4 rounded-sm hover:bg-slate-800 transition-colors shadow-md mt-6 text-lg tracking-wide">
      Submit Request
    </button>
  </div>
</form>
