---
---
<header class="sticky top-0 z-50 bg-stone-50 border-b border-stone-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="text-2xl font-extrabold text-slate-900 tracking-tight flex items-center gap-2">
          <!-- Geometric Tile Icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-teal-700">
            <rect x="2" y="2" width="9" height="9" fill="currentColor" class="opacity-80" />
            <rect x="13" y="13" width="9" height="9" fill="currentColor" />
            <rect x="13" y="2" width="9" height="9" stroke="currentColor" stroke-width="2" />
            <rect x="2" y="13" width="9" height="9" stroke="currentColor" stroke-width="2" />
          </svg>
          Artistic Tile <span class="text-teal-700">Setting</span>
        </a>
      </div>
      
      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8 items-center" aria-label="Main Navigation">
        <a href="/" class="text-slate-600 hover:text-teal-700 font-semibold transition-colors duration-200 text-sm tracking-wide">Home</a>
        <a href="/services" class="text-slate-600 hover:text-teal-700 font-semibold transition-colors duration-200 text-sm tracking-wide">Services</a>
        <a href="/portfolio" class="text-slate-600 hover:text-teal-700 font-semibold transition-colors duration-200 text-sm tracking-wide">Portfolio</a>
        <a href="/about" class="text-slate-600 hover:text-teal-700 font-semibold transition-colors duration-200 text-sm tracking-wide">About</a>
        <a href="/contact" class="text-slate-600 hover:text-teal-700 font-semibold transition-colors duration-200 text-sm tracking-wide">Contact</a>
        
        <!-- CTA Button -->
        <a href="tel:9177740100" class="bg-teal-700 text-white px-5 py-2.5 rounded-sm font-bold hover:bg-teal-800 transition-colors duration-200 shadow-md flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z" clip-rule="evenodd" />
          </svg>
          (917) 774-0100
        </a>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open Menu" class="text-slate-900 hover:text-teal-700 focus:outline-none p-2 relative group">
          <div class="w-6 flex flex-col items-end gap-1.5 transition-all">
            <span class="w-6 h-0.5 bg-current rounded-sm transition-all duration-300 origin-right"></span>
            <span class="w-6 h-0.5 bg-current rounded-sm transition-all duration-300"></span>
            <span class="w-4 h-0.5 bg-current rounded-sm transition-all duration-300 origin-right group-hover:w-6"></span>
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden bg-stone-50 border-t border-stone-200 absolute w-full left-0 shadow-xl overflow-hidden" aria-hidden="true">
    <div class="px-6 py-8 space-y-6 flex flex-col uppercase tracking-widest">
      <a href="/" class="text-slate-800 font-bold hover:text-teal-700 text-lg transition-colors">Home</a>
      <a href="/services" class="text-slate-800 font-bold hover:text-teal-700 text-lg transition-colors">Services</a>
      <a href="/portfolio" class="text-slate-800 font-bold hover:text-teal-700 text-lg transition-colors">Portfolio</a>
      <a href="/about" class="text-slate-800 font-bold hover:text-teal-700 text-lg transition-colors">About</a>
      <a href="/contact" class="text-slate-800 font-bold hover:text-teal-700 text-lg transition-colors">Contact</a>
      <div class="pt-6 border-t border-stone-200 mt-2">
        <a href="tel:9177740100" class="bg-teal-700 text-white w-full flex justify-center items-center py-4 rounded-sm font-bold shadow-md hover:bg-teal-800 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 mr-2">
            <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z" clip-rule="evenodd" />
          </svg>
          (917) 774-0100
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', (!isExpanded).toString());
      menu.setAttribute('aria-hidden', isExpanded.toString());
      
      // Animate hamburger to X
      const bars = btn.querySelectorAll('span');
      if (!isExpanded) {
        bars[0].style.transform = 'rotate(-45deg) translate(-5px, 6px)';
        bars[1].style.opacity = '0';
        bars[2].style.transform = 'rotate(45deg) translate(-5px, -6px)';
        bars[2].classList.remove('w-4');
        bars[2].classList.add('w-6');
      } else {
        bars[0].style.transform = 'none';
        bars[1].style.opacity = '1';
        bars[2].style.transform = 'none';
        bars[2].classList.remove('w-6');
        bars[2].classList.add('w-4');
      }
    });
  }
</script>
