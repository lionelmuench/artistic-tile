---
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero_background_1772650134156.png';
---
<section class="bg-stone-50 pt-12 pb-20 lg:pt-24 lg:pb-32 overflow-hidden relative">
  <!-- Subtle background decoration -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-teal-50/50 via-stone-50 to-stone-50"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="lg:grid lg:grid-cols-12 lg:gap-16 items-center">
      
      <!-- Text Content -->
      <div class="lg:col-span-6 lg:pb-0 pb-12">
        <h1 class="text-4xl md:text-5xl lg:text-tight font-extrabold text-slate-900 tracking-tight leading-tight mb-6">
          Expert Tile Installation & <br class="hidden lg:block"/>Bathroom Remodeling <br class="hidden lg:block"/>in <span class="text-teal-700 relative whitespace-nowrap"><span class="relative z-10">New York City</span><span class="absolute bottom-1 left-0 w-full h-3 bg-teal-200/60 -z-10 transform -rotate-1 rounded-sm"></span></span>
        </h1>
        
        <p class="text-lg md:text-xl text-slate-600 mb-10 leading-relaxed font-light">
          We are a family-owned and operated contractor specializing in precision ceramic and porcelain tile, full kitchen and bath remodels, and commercial tile services. Quality craftsmanship you can depend on.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="inline-flex justify-center items-center bg-teal-700 hover:bg-teal-800 text-white px-8 py-4 rounded-sm font-bold text-lg transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-0.5 group">
            Get a Free Estimate
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="tel:9147740100" class="inline-flex justify-center items-center bg-white hover:bg-stone-100 text-slate-900 border border-stone-200 px-8 py-4 rounded-sm font-bold text-lg transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5">
            Call (914) 774-0100
          </a>
        </div>
        
        <div class="mt-10 flex items-center gap-4 text-sm font-medium text-slate-500">
          <div class="flex text-teal-500">
             {[...Array(5)].map(() => (
                <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
             ))}
          </div>
          <span>5-Star Rated in NYC</span>
        </div>
      </div>
      
      <!-- Image Content -->
      <div class="lg:col-span-6 relative z-10">
        <!-- Main Image -->
        <div class="relative rounded-sm overflow-hidden shadow-2xl aspect-[4/3] lg:aspect-[3/4] max-h-[600px] w-full bg-stone-200 border-4 border-white">
          <Image src={heroImg} class="absolute inset-0 w-full h-full object-cover transform hover:scale-105 transition-transform duration-1000" alt="Beautifully tiled modern bathroom" />
          <div class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-sm"></div>
        </div>
        
        <!-- Decorative Elements -->
        <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-stone-200 rounded-sm -z-10 opacity-60" style="background-image: radial-gradient(#78716c 2px, transparent 2px); background-size: 16px 16px;"></div>
        <div class="absolute -top-8 -right-8 w-48 h-48 bg-teal-100 rounded-full -z-10 blur-3xl opacity-60"></div>
        
        <!-- Floating Badge -->
        <div class="absolute -bottom-6 -right-4 bg-white p-4 rounded-sm shadow-xl flex items-center gap-4 border border-stone-100 animate-fade-in-up">
          <div class="w-12 h-12 bg-teal-50 rounded-full flex items-center justify-center text-teal-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 font-medium uppercase tracking-wider">Licensed & Insured</p>
            <p class="text-sm font-bold text-slate-900">Craftsmanship Guaranteed</p>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>
