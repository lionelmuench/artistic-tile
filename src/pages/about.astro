---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About Us | Artistic Tile Setting Inc." description="Family-owned tile contractor in Westchester, NY with over 6 years of experience. Licensed, Insured, and Bonded.">
  <Header slot="header" />
  
  <div class="bg-stone-900 pt-32 pb-20 px-4 sm:px-6 lg:px-8 text-center text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#d6d3d1 1px, transparent 1px); background-size: 32px 32px;"></div>
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6">About Artistic Tile Setting Inc.</h1>
    <div class="h-1 w-20 bg-teal-600 mx-auto rounded-sm mb-6"></div>
    <p class="text-xl text-stone-300 max-w-2xl mx-auto font-light">Committed to craftsmanship, precision, and the Westchester community.</p>
  </div>

  <section class="py-20 bg-stone-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row gap-16 items-center">
        <!-- Story -->
        <div class="w-full md:w-3/5 space-y-6">
          <h2 class="text-3xl font-bold text-slate-900 tracking-tight">Family Owned & Operated</h2>
          <p class="text-lg text-slate-700 leading-relaxed font-light">
            Based in Westchester, NY, Artistic Tile Setting Inc. is a family-owned contracting business born out of a profound dedication to the craft of tile setting and remodeling. For over <strong>6 years</strong>, we have been helping homeowners and businesses throughout Westchester County realize the full potential of their spaces through meticulous tile work.
          </p>
          <p class="text-lg text-slate-700 leading-relaxed font-light">
            Our founder Anthony personally oversees projects to guarantee the standard of excellence that keeps our customers referring us to their friends and neighbors. We show up on time, communicate clearly, and leave your home as clean as we found it.
          </p>
        </div>

        <!-- Trust Signals -->
        <div class="w-full md:w-2/5">
          <div class="bg-white p-8 border-t-4 border-teal-700 shadow-xl rounded-sm">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">Why Choose Us</h3>
            <ul class="space-y-5">
              <li class="flex items-start">
                  <div class="bg-green-100 p-2 rounded-sm text-green-700 mr-4">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  </div>
                  <div>
                      <strong class="block text-slate-900 mb-1">6+ Years Experience</strong>
                      <span class="text-slate-600 text-sm">A proven track record of successful remodels and structural repairs.</span>
                  </div>
              </li>
              <li class="flex items-start">
                  <div class="bg-green-100 p-2 rounded-sm text-green-700 mr-4">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  </div>
                  <div>
                      <strong class="block text-slate-900 mb-1">Fully Licensed & Insured</strong>
                      <span class="text-slate-600 text-sm">We are bonded and carry comprehensive liability insurance for your peace of mind.</span>
                  </div>
              </li>
              <li class="flex items-start">
                  <div class="bg-green-100 p-2 rounded-sm text-green-700 mr-4">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  </div>
                  <div>
                      <strong class="block text-slate-900 mb-1">Free Quotes</strong>
                      <span class="text-slate-600 text-sm">No hidden fees or surprise upcharges. We provide accurate, transparent estimates upfront.</span>
                  </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 bg-slate-900 border-t-4 border-teal-700 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white mb-6">Ready to bring your vision to life?</h2>
      <a href="/contact" class="inline-block bg-teal-700 hover:bg-teal-600 text-white px-8 py-4 rounded-sm font-bold text-lg transition-colors shadow-lg">
        Contact Anthony Today
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
