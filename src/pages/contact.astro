---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Contact Us | Artistic Tile Setting Inc." description="Contact Artistic Tile Setting Inc. in Westchester, NY for a free estimate on your next tile or remodeling project." isContact={true}>
  <Header slot="header" />
  
  <div class="bg-stone-900 pt-32 pb-20 px-4 sm:px-6 lg:px-8 text-center text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#d6d3d1 1px, transparent 1px); background-size: 32px 32px;"></div>
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6">Contact Us</h1>
    <div class="h-1 w-20 bg-teal-600 mx-auto rounded-sm mb-6"></div>
    <p class="text-xl text-stone-300 max-w-2xl mx-auto font-light">Get in touch for a free estimate or to discuss your upcoming project.</p>
  </div>

  <section class="py-20 bg-stone-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-16">
        
        <!-- Contact Information -->
        <div class="w-full lg:w-1/3 space-y-10">
          <div>
            <h2 class="text-3xl font-bold text-slate-900 mb-6 tracking-tight">Get In Touch</h2>
            <p class="text-lg text-slate-600 leading-relaxed font-light mb-8">
              Whether you need a minor grout repair or a complete master bathroom overhaul, we're here to help. Reach out via phone or fill out the form, and we'll get back to you promptly.
            </p>
          </div>

          <div class="space-y-6">
            <div class="flex items-start">
              <div class="bg-teal-100 p-3 rounded-sm text-teal-700 mr-4">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <strong class="block text-slate-900 mb-1 text-lg">Call Us Directly</strong>
                <a href="tel:9147740100" class="text-slate-600 hover:text-teal-700 transition-colors font-semibold text-lg hover:underline">(914) 774-0100</a>
                <p class="text-slate-500 text-sm mt-1">Available Mon-Sat, 8am - 6pm</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-teal-100 p-3 rounded-sm text-teal-700 mr-4">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <strong class="block text-slate-900 mb-1 text-lg">Email Us</strong>
                <a href="mailto:info@artistictilesetting.com" class="text-slate-600 hover:text-teal-700 transition-colors font-semibold hover:underline">info@artistictilesetting.com</a>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-teal-100 p-3 rounded-sm text-teal-700 mr-4">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <strong class="block text-slate-900 mb-1 text-lg">Service Area</strong>
                <address class="not-italic text-slate-600 leading-relaxed">
                  94 Davenport Rd<br />
                  Westchester, NY 10710
                </address>
                <p class="text-slate-500 text-sm mt-2 font-medium">Proudly serving Westchester, Westchester County, and surrounding areas.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="w-full lg:w-2/3">
          <ContactForm />
        </div>
        
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
